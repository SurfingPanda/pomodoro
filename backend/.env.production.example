# Production env reference for Render. Do NOT commit real secrets — set these
# in the Render dashboard (Environment tab) or via the render.yaml Blueprint.
# Copy the DB_* and SUPABASE_* values from your local backend/.env.

APP_NAME=Pomodoro
APP_ENV=production
APP_DEBUG=false
APP_KEY=            # php artisan key:generate --show  → paste base64:...
APP_URL=            # https://pomodoro-api.onrender.com (your Render URL)

LOG_CHANNEL=stderr

# Stateless token-auth API — no DB sessions/queue needed.
SESSION_DRIVER=array
CACHE_STORE=file
QUEUE_CONNECTION=sync

# Supabase Postgres (session pooler). Copy from local .env.
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_SSLMODE=require

# Supabase Auth — used by VerifySupabaseToken middleware.
SUPABASE_URL=
SUPABASE_ANON_KEY=
